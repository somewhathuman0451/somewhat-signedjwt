{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MockQuoteApi": {
    "BaseAddress": "http://localhost:5130/"
  },
  "DemoClientProfiles": {
    "DefaultProfileName": "standard",
    "Profiles": [
      {
        "Name": "standard",
        "DisplayName": "Standard Partner",
        "ApiKey": "demo-api-key-a",
        "CertificateName": "alpha"
      },
      {
        "Name": "standard",
        "DisplayName": "Standard Partner",
        "ApiKey": "demo-api-key-a",
        "CertificateName": "alpha",
        "Description": "Valid profile using the alpha certificate.",
        "ExpectedSuccess": true
      },
      {
        "Name": "priority",
        "DisplayName": "Priority Partner",
        "ApiKey": "demo-api-key-b",
        "CertificateName": "beta",
        "Description": "Valid profile using the beta certificate.",
        "ExpectedSuccess": true
      },
      {
        "Name": "negative-mismatch",
        "DisplayName": "Negative Demo: Mismatched Certificate",
        "ApiKey": "demo-api-key-a",
        "CertificateName": "beta",
        "Description": "Intentionally uses Standard Partner's API key with the beta certificate so the mock rejects it.",
        "ExpectedSuccess": false
      },
      {
        "Name": "negative-unknown-key",
        "DisplayName": "Negative Demo: Unknown API Key",
        "ApiKey": "demo-api-key-unknown",
        "CertificateName": "alpha",
        "Description": "Uses a certificate the mock recognizes, but an API key the mock does not know, so the request is rejected before certificate pairing matters.",
        "ExpectedSuccess": false
      }
    ]
  },
  "SignedJwtClient": {
    "Issuer": "somewhat-signedjwt-sample",
    "Audience": "somewhat-signedjwt-mock-service",
    "Subject": "",
    "ApiKeyClaimName": "client_id",
    "Scope": "quotes.read",
    "TokenLifetime": "00:05:00"
  },
  "CertificateSource": {
    "DefaultCertificateName": "alpha",
    "Certificates": [
      {
        "Name": "alpha",
        "Source": "PemFiles"
      },
      {
        "Name": "beta",
        "Source": "PemFiles"
      }
    ]
  },
  "AllowedHosts": "*"
}
